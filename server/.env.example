# DoLike Server 环境变量配置

# ============================================================
# 基本配置
# ============================================================

# 后端监听端口（默认 7777）
# 仅绑定 127.0.0.1，不对外暴露
PORT=7777

# 数据存储根目录
# 所有归档内容、数据库、日志均存储在此目录下
# 默认：~/.dolike-archive
# ARCHIVE_ROOT=~/.dolike-archive

# ============================================================
# 数据库配置
# ============================================================

# Prisma 数据库连接串
# 开发环境：使用 SQLite 文件（项目根目录下的 dev.db）
DATABASE_URL="file:./dev.db"

# 生产环境示例（Docker）：
# DATABASE_URL="file:/data/db/app.sqlite"

# 生产环境示例（本地）：
# DATABASE_URL="file:/Users/<username>/.dolike-archive/db/app.sqlite"

# ============================================================
# 日志配置
# ============================================================

# 日志级别：trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# 是否启用 pino-pretty（控制台美化输出）
# 开发环境推荐 true，生产环境建议 false
LOG_PRETTY=true

# ============================================================
# 下载配置
# ============================================================

# 下载并发数（默认 3，通过前端设置页面修改）
# DOWNLOAD_CONCURRENCY=3

# 视频长短阈值（秒，默认 60，通过前端设置页面修改）
# SHORT_VIDEO_SEC=60

# ============================================================
# 抖音相关
# ============================================================

# 抖音 API 域名（一般不需要修改）
# DOUYIN_API_HOST=https://www.douyin.com

# ============================================================
# 安全相关
# ============================================================

# 会话密钥（用于签名 session cookie，生产环境建议设置）
# SESSION_SECRET=your-random-secret-here

# ============================================================
# Docker 环境
# ============================================================

# Docker 部署时设置：
# NODE_ENV=production
# PORT=3000
# ARCHIVE_ROOT=/data
# DATABASE_URL=file:/data/db/app.sqlite
# LOG_LEVEL=info
# LOG_PRETTY=false
