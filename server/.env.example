# server 默认从 ~/.dolike-archive 读取配置 / 数据
# 这里仅列出可被环境变量覆盖的项

# 后端监听端口（默认 7777，仅绑 127.0.0.1）
PORT=7777

# Prisma DATABASE_URL：开发期默认走 server/prisma/dev.db，
# 生产期由 config.ts 改写为 ~/.dolike-archive/db/app.sqlite
DATABASE_URL="file:./dev.db"

# 日志级别 trace|debug|info|warn|error|fatal
LOG_LEVEL=info

# 是否启用 pino-pretty（dev=true，prod=false）
LOG_PRETTY=true
