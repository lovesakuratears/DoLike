    "fastify-plugin": "^4.5.1",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playwright-core": "^1.60.0",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "prisma": "^5.22.0",
